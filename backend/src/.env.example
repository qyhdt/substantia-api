# 复制为 .env 后按需修改：cp .env.example .env
# .env 不入库（见 .gitignore）

# ---------- HTTP ----------
HOST=0.0.0.0
PORT=7999
REQUEST_LATENCY_THRESHOLD=2.0
LOG_REQUEST_PARAMS=false

# ---------- CORS ----------
# 逗号分隔的允许来源，如 https://app.substantia.ai,https://substantia.ai
CORS_ORIGINS=
# 默认仅放行 localhost；生产按需放宽
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# ---------- 鉴权 ----------
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_LONG_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=1440
AUTH_TOKEN_EXPIRE_HOURS=1440
# 本地/测试可设 true 跳过鉴权（require_access_token 返回 dummy user）
AUTH_DISABLED=false
AUTH_COOKIE=substantia_access_token

# ---------- 权限 ----------
# /api/admin/* 白名单邮箱，逗号分隔；空 = 没人能用
ADMIN_EMAILS=

# ---------- Redis（可选）----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ---------- PostgreSQL（可选）----------
# 留空 = 不启用 DB / 不跑 migrations
DATABASE_URL=
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=20
DB_COMMAND_TIMEOUT=60
