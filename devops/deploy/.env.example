# 复制为 .env 填真实值；.env 不入库。
# 生成密钥：openssl rand -hex 32

# ---- DB ----
DB_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://substantia:CHANGE_ME@substantia-api-db:5432/substantia

# ---- 鉴权 ----
JWT_SECRET=CHANGE_ME_LONG_RANDOM
AUTH_DISABLED=false
AUTH_COOKIE=substantia_access_token
# admin 白名单（逗号分隔），portal/admin 接口用
ADMIN_EMAILS=cja.china@gmail.com

# ---- CORS（前端域名）----
CORS_ORIGINS=https://dev.substantia.ai,https://api.substantia.ai

# ---- Claude 容器 / slot ----
CLAUDE_WORKSPACE_ROOT=/var/lib/substantia/claude
CLAUDE_SLOTS_FILE=/var/lib/substantia/claude/slots.json
CLAUDE_BASE_IMAGE=claude-runner
CLAUDE_PROBE_ENABLED=true

# ---- Claude 固定三级故障转移 ----
# 严格顺序：subscription(priority=0) -> moxing(priority=100) -> Gemini(priority=200)。
# subscription 来自上面的 slot/账号池；以下两档只在前一档不可用时启用。
# 档表在 backend/src/services/claude/registry.py 的 FALLBACK_TIERS；每档三件套配齐才启用。
#
# moxing：Anthropic 兼容网关，订阅池不可用后的第一档兜底。
CLAUDE_FALLBACK_MOXING_BASE_URL=
CLAUDE_FALLBACK_MOXING_AUTH_TOKEN=
CLAUDE_FALLBACK_MOXING_MODEL=

# GLM 5.2 / Kimi K3 公开模型直连；留空则复用上面的 moxing BASE_URL/AUTH_TOKEN。
# 如需独立凭据再填写，真实 token 仍只放服务器 .env。
MOXING_API_BASE=
MOXING_API_KEY=

# Gemini 复用同机已有的 LiteLLM Anthropic bridge（参考栈默认监听 172.17.0.1:4000）。
# AUTH_TOKEN 填 LiteLLM master token，不是 Gemini/aicenter 的上游 key；三项齐全才启用。
CLAUDE_FALLBACK_GEMINI_BASE_URL=http://172.17.0.1:4000
CLAUDE_FALLBACK_GEMINI_AUTH_TOKEN=
CLAUDE_FALLBACK_GEMINI_MODEL=gemini-3.5-flash

# USD/CNY 最新参考汇率（Frankfurter，无需 API key）；失败时回退 XUNHUPAY_RMB_PER_USD。
FX_USD_CNY_URL=https://api.frankfurter.dev/v2/rate/USD/CNY
FX_RATE_CACHE_SECONDS=3600
XUNHUPAY_RMB_PER_USD=7.2

# 安全：真实 token 只填在 devops/deploy/.env；不要提交，也不要放进前端或 slot JSON/CRUD。
