# 复制为 .env 填真实值；.env 不入库。
# 生成密钥：openssl rand -hex 32

# ---- DB ----
DB_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://substantia:CHANGE_ME@substantia-api-db:5432/substantia

# ---- 鉴权 ----
JWT_SECRET=CHANGE_ME_LONG_RANDOM
AUTH_DISABLED=false
AUTH_COOKIE=substantia_access_token
# admin 白名单（逗号分隔），portal/admin 接口用
ADMIN_EMAILS=cja.china@gmail.com

# ---- CORS（前端域名）----
CORS_ORIGINS=https://dev.substantia.ai,https://api.substantia.ai

# ---- Claude 容器 / slot ----
CLAUDE_WORKSPACE_ROOT=/var/lib/substantia/claude
CLAUDE_SLOTS_FILE=/var/lib/substantia/claude/slots.json
CLAUDE_BASE_IMAGE=claude-runner
CLAUDE_PROBE_ENABLED=true
